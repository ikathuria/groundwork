# Copy to `.env` (or `.env.local` for the Next.js app) and fill in.
# Never commit the populated `.env` file.

# ---- Required ----

# Anthropic API key. Used by Claude Code (interactive) and `claude -p` (headless).
ANTHROPIC_API_KEY=

# ---- Optional ----

# Semantic Scholar API key — higher rate limits during deep-research passes.
# Get one at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# OpenAI API key — only if running Codex as the pipeline driver instead of Claude Code.
OPENAI_API_KEY=

# Path override if `claude` is not on PATH (used by Layer B headless invocations).
# CLAUDE_BIN=/usr/local/bin/claude

# Path override if `codex` is not on PATH.
# CODEX_BIN=/usr/local/bin/codex

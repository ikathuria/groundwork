# Copy to `.env` (or `.env.local` for the Next.js app) and fill in.
# Never commit the populated `.env` file.

# ---- Required ----

# Anthropic API key. Used by Claude Code (interactive) and `claude -p` (headless pipeline).
ANTHROPIC_API_KEY=

# ---- Optional ----

# Semantic Scholar API key — higher rate limits during Pass 1 literature search.
# Get one at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Path override if `claude` is not on PATH (used by the headless pipeline subprocess).
# CLAUDE_BIN=/usr/local/bin/claude

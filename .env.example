# Copy to `.env` (or `.env.local` for the Next.js app) and fill in.
# Never commit the populated `.env` file.

# ---- Required ----

# Anthropic API key. Used by Claude Code (interactive) and `claude -p` (headless pipeline).
ANTHROPIC_API_KEY=

# ---- Optional ----

# Semantic Scholar API key — higher rate limits during Pass 1 literature search.
# Get one at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Path override if `claude` is not on PATH (used by the headless pipeline subprocess).
# CLAUDE_BIN=/usr/local/bin/claude

# ---- Deployment (Railway) ----

# On Railway, mount a persistent volume at /app/hypotheses so that downloaded
# papers and compiled wikis survive redeploys. The volume is created automatically
# via railway.toml. No env var is required — Next.js reads from process.cwd().
#
# To deploy:
#   1. Push this repo to GitHub.
#   2. Create a new Railway project → "Deploy from GitHub repo".
#   3. Add the required env vars above in Railway's Variables tab.
#   4. Railway uses railway.toml + Dockerfile automatically.
#   5. The volume defined in railway.toml is mounted at /app/hypotheses.
#
# Local Docker run (for testing the production image):
#   docker build -t groundwork .
#   docker run -p 3000:3000 \
#     -v $(pwd)/hypotheses:/app/hypotheses \
#     -e ANTHROPIC_API_KEY=sk-ant-... \
#     groundwork
